<Window x:Class="Lab2_DoubleCycleList.Views.ProcessListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Process List — Polynomial Addition" Height="500" Width="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Background="#C8E6C9" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Polynomial Addition" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" Foreground="#1B5E20" HorizontalAlignment="Center"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="P(x)" FontSize="14" FontWeight="Bold" Foreground="#1B5E20" Margin="0,0,0,5"/>
                <DataGrid x:Name="dgPoly1" Background="White" FontFamily="Consolas" FontSize="12"
                          Height="100" AutoGenerateColumns="False" IsReadOnly="True"
                          HeadersVisibility="Column" GridLinesVisibility="All"
                          RowBackground="#E8F5E9" AlternatingRowBackground="#C8E6C9">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Pos" Binding="{Binding Position}" Width="50"/>
                        <DataGridTextColumn Header="Coefficient" Binding="{Binding Coefficient}" Width="*"/>
                        <DataGridTextColumn Header="Power" Binding="{Binding Power}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
                <TextBlock x:Name="txtPoly1Str" TextWrapping="Wrap" FontSize="13" Margin="0,8,0,0" FontWeight="SemiBold" Foreground="#2E7D32"/>
            </StackPanel>

            <TextBlock Grid.Column="1" Text="+" VerticalAlignment="Center" FontSize="32" FontWeight="Bold" Foreground="#2E7D32"/>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Q(x)" FontSize="14" FontWeight="Bold" Foreground="#1B5E20" Margin="0,0,0,5"/>
                <DataGrid x:Name="dgPoly2" Background="White" FontFamily="Consolas" FontSize="12"
                          Height="100" AutoGenerateColumns="False" IsReadOnly="True"
                          HeadersVisibility="Column" GridLinesVisibility="All"
                          RowBackground="#E8F5E9" AlternatingRowBackground="#C8E6C9">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Pos" Binding="{Binding Position}" Width="50"/>
                        <DataGridTextColumn Header="Coefficient" Binding="{Binding Coefficient}" Width="*"/>
                        <DataGridTextColumn Header="Power" Binding="{Binding Power}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
                <TextBlock x:Name="txtPoly2Str" TextWrapping="Wrap" FontSize="13" Margin="0,8,0,0" FontWeight="SemiBold" Foreground="#2E7D32"/>
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="2" Text="=" HorizontalAlignment="Center" FontSize="28" FontWeight="Bold" Foreground="#2E7D32" Margin="0,10,0,10"/>

        <StackPanel Grid.Row="3">
            <TextBlock Text="S(x) = P(x) + Q(x)" FontSize="16" FontWeight="Bold" Foreground="#1B5E20" HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock x:Name="txtResultStr" TextWrapping="Wrap" FontSize="18" FontWeight="Bold" Foreground="#2E7D32" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <DataGrid x:Name="dgResult" Background="White" FontFamily="Consolas" FontSize="12"
                      Height="80" AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="All"
                      RowBackground="#E8F5E9" AlternatingRowBackground="#C8E6C9">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Pos" Binding="{Binding Position}" Width="50"/>
                    <DataGridTextColumn Header="Coefficient" Binding="{Binding Coefficient}" Width="*"/>
                    <DataGridTextColumn Header="Power" Binding="{Binding Power}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>

        <Button Grid.Row="4" Content="OK" Width="80" HorizontalAlignment="Center" Margin="0,20,0,0"
                IsDefault="True" Background="#4CAF50" Foreground="White" FontWeight="SemiBold" Click="OK_Click"/>
    </Grid>
</Window>