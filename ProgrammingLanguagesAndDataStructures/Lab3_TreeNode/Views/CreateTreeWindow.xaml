<Window x:Class="Lab3_Tree.Views.CreateTreeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Tree" Height="400" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="#C8E6C9">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Enter tree nodes (one per line: key,info):" 
                   FontSize="14" Foreground="#1B5E20" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="1" Text="Example: 10,A" 
                   FontSize="12" Foreground="#388E3C" Margin="0,0,0,10" FontStyle="Italic"/>

        <TextBox x:Name="txtInput" Grid.Row="2" 
                 AcceptsReturn="True" 
                 TextWrapping="Wrap" 
                 VerticalScrollBarVisibility="Auto"
                 FontSize="14" Padding="8"
                 FontFamily="Consolas"/>

        <TextBlock Grid.Row="3" Text="Format: integer_key,char_info (one pair per line)" 
                   FontSize="11" Foreground="#388E3C" Margin="0,10,0,5"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Margin="0,0,10,0" Background="#4CAF50" Foreground="White"
                    IsDefault="True" Click="OK_Click"/>
            <Button Content="Cancel" Width="80" IsCancel="True" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>