<Window x:Class="Lab3_Tree.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lab3_Tree"
        mc:Ignorable="d"
        Title="Binary Search Tree" Height="500" Width="850">
    <DockPanel Background="#C8E6C9">

        <Menu DockPanel.Dock="Top" Background="#81C784" Padding="5">
            <MenuItem Header="About" Foreground="#1B5E20" FontWeight="SemiBold" Click="ShowAbout_Click"/>

            <MenuItem Header="Task" Foreground="#1B5E20" FontWeight="SemiBold">
                <MenuItem Header="Create Tree" Click="CreateTree_Click"/>
                <MenuItem Header="Process Tree" Click="ProcessTree_Click"/>
                <MenuItem Header="Destroy Tree" Click="DestroyTree_Click"/>
            </MenuItem>

            <MenuItem Header="Exit" Foreground="#2C3E50" FontWeight="SemiBold" Click="Exit_Click"/>
        </Menu>

        <Grid>
            <Grid x:Name="EmptyPanel" Visibility="Visible" Grid.ColumnSpan="2">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock FontFamily="Consolas" FontSize="14" Foreground="#388E3C" HorizontalAlignment="Center" Margin="0,0,0,15">
                        <Run Text=" /\_/\  "/><LineBreak/>
                        <Run Text="( o.o ) "/><LineBreak/>
                        <Run Text=" > ^ &lt; "/><LineBreak/> <Run Text=" /| |\  "/><LineBreak/>
                        <Run Text="(_|_)   "/>
                    </TextBlock>
                    <TextBlock Text="Select an option from the menu"
                               HorizontalAlignment="Center"
                               FontSize="16" Foreground="#2E7D32"/>
                </StackPanel>
            </Grid>

            <Grid x:Name="AboutPanel" Visibility="Collapsed" Grid.ColumnSpan="2" Margin="20" Background="White">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="About Program" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" Foreground="#1B5E20" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtTaskDescription" TextWrapping="Wrap" FontSize="16" Margin="0,0,0,10" TextAlignment="Center"/>
                    <TextBlock x:Name="txtStudentInfo" TextWrapping="Wrap" FontSize="16" FontWeight="Medium" TextAlignment="Center"/>
                </StackPanel>
            </Grid>

            <Grid x:Name="MainWorkArea" Visibility="Collapsed" Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="txtTreeDisplay" Text="Tree: " FontSize="14" Foreground="#1B5E20" Margin="0,0,0,10"/>
                <TreeView x:Name="treeView" Grid.Row="1" FontFamily="Consolas" FontSize="14" Background="White" Padding="10"/>
            </Grid>
        </Grid>

    </DockPanel>
</Window>