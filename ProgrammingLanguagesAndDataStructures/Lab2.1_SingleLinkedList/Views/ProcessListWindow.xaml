<Window x:Class="Lab2_Lists1.Views.ProcessListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Process List — Polynomial Addition" Height="550" Width="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Background="#C8E6C9" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Polynomial Addition" FontSize="16" FontWeight="Bold" Margin="0,0,0,15" Foreground="#1B5E20"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <GroupBox Header="P(x)" BorderBrush="#388E3C" BorderThickness="2" Padding="10" Margin="0,0,0,10">
                    <DataGrid x:Name="dgPoly1" Background="White" FontFamily="Consolas" FontSize="12"
                              Height="180" AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" GridLinesVisibility="All"
                              RowBackground="#E8F5E9" AlternatingRowBackground="#C8E6C9">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Pos" Binding="{Binding Position}" Width="50"/>
                            <DataGridTextColumn Header="Coefficient" Binding="{Binding Coefficient}" Width="*"/>
                            <DataGridTextColumn Header="Power" Binding="{Binding Power}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>
                <TextBlock x:Name="txtPoly1Str" TextWrapping="Wrap" FontSize="13" Margin="5,0"/>
            </StackPanel>

            <TextBlock Grid.Column="2" Text="+" VerticalAlignment="Center" FontSize="28" FontWeight="Bold" Foreground="#2E7D32"/>

            <StackPanel Grid.Column="4">
                <GroupBox Header="Q(x)" BorderBrush="#388E3C" BorderThickness="2" Padding="10" Margin="0,0,0,10">
                    <DataGrid x:Name="dgPoly2" Background="White" FontFamily="Consolas" FontSize="12"
                              Height="180" AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" GridLinesVisibility="All"
                              RowBackground="#E8F5E9" AlternatingRowBackground="#C8E6C9">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Pos" Binding="{Binding Position}" Width="50"/>
                            <DataGridTextColumn Header="Coefficient" Binding="{Binding Coefficient}" Width="*"/>
                            <DataGridTextColumn Header="Power" Binding="{Binding Power}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>
                <TextBlock x:Name="txtPoly2Str" TextWrapping="Wrap" FontSize="13" Margin="5,0"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1" Margin="0,280,0,0">
            <TextBlock Text="=" HorizontalAlignment="Center" FontSize="24" FontWeight="Bold" Foreground="#2E7D32"/>
            <GroupBox Header="Result" BorderBrush="#388E3C" BorderThickness="2" Padding="10" Margin="0,5,0,0">
                <StackPanel>
                    <DataGrid x:Name="dgResult" Background="White" FontFamily="Consolas" FontSize="12"
                              Height="180" AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" GridLinesVisibility="All"
                              RowBackground="#E8F5E9" AlternatingRowBackground="#C8E6C9">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Pos" Binding="{Binding Position}" Width="50"/>
                            <DataGridTextColumn Header="Coefficient" Binding="{Binding Coefficient}" Width="*"/>
                            <DataGridTextColumn Header="Power" Binding="{Binding Power}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock x:Name="txtResultStr" TextWrapping="Wrap" FontSize="13" Margin="5,5,0,0" FontWeight="SemiBold"/>
                </StackPanel>
            </GroupBox>
        </StackPanel>

        <Button Grid.Row="2" Content="OK" Width="80" HorizontalAlignment="Center" Margin="0,15,0,0"
                IsDefault="True" Background="#4CAF50" Foreground="White" FontWeight="SemiBold" Click="OK_Click"/>
    </Grid>
</Window>
